{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/webview/app.ts",
    "src/core/warm-up-worker.ts",
    "src/core/parse-worker.ts",
    "src/core/cache-write-worker.ts",
    "src/core/parser.bench.ts",
    "src/cli/index.ts",
    "src/cli/browser/analyzer-entry.ts",
    "src/cli/browser/shared-browser.ts",
    "src/cli/browser/stub-analyzer-config.ts",
    "src/cli/browser/stub-rule-loader.ts"
  ],
  "project": ["src/**/*.ts"],
  "ignore": [
    "src/webview/page-insights.ts",
    "src/webview/page-rule-editor.ts",
    "src/webview/page-workflows.ts",
    "src/webview/vibe-roles.ts",
    "src/spike-browser-analyzer.ts"
  ],
  "ignoreDependencies": ["lint-staged", "serve"],
  "ignoreBinaries": ["tsx", "sqlite3", "open", "xdg-open"],
  "rules": {
    "exports": "off",
    "types": "off",
    "enumMembers": "off"
  }
}
