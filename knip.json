{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "packages/core": {
      "entry": [
        "src/warm-up-worker.ts",
        "src/parse-worker.ts",
        "src/cache-write-worker.ts"
      ],
      "project": ["src/**/*.ts"]
    },
    "apps/cli": {
      "entry": [
        "src/webview/app.ts",
        "src/index.ts",
        "src/browser/analyzer-entry.ts",
        "src/browser/shared-browser.ts",
        "src/browser/stub-analyzer-config.ts",
        "src/browser/stub-rule-loader.ts"
      ],
      "project": ["src/**/*.ts"],
      "ignore": [
        "src/webview/page-insights.ts",
        "src/webview/page-rule-editor.ts",
        "src/webview/page-workflows.ts",
        "src/webview/vibe-roles.ts"
      ]
    },
    "apps/dashboard": {
      "entry": ["src/app/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    ".": {
      "entry": ["scripts/**/*.{ts,mjs}"],
      "project": ["scripts/**/*.{ts,mjs}"]
    }
  },
  "ignoreDependencies": ["lint-staged", "serve", "@nx/next", "@nx/eslint", "esbuild"],
  "ignoreBinaries": ["tsx", "sqlite3", "open", "xdg-open"],
  "ignore": [],
  "rules": {
    "exports": "off",
    "types": "off",
    "enumMembers": "off"
  }
}
